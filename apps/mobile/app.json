{
  "expo": {
    "name": "Pet Ecosystem",
    "slug": "pet-ecosystem",
    "version": "0.0.0",
    "scheme": "petecosystem",
    "orientation": "portrait",
    "icon": "./assets/brand/pet-ecosystem-app-icon.png",
    "splash": {
      "image": "./assets/brand/pet-ecosystem-logo-mark.png",
      "resizeMode": "contain",
      "backgroundColor": "#f8f4ec"
    },
    "platforms": [
      "ios",
      "android",
      "web"
    ],
    "ios": {
      "bundleIdentifier": "com.petecosystem.mobile"
    },
    "android": {
      "package": "com.petecosystem.mobile",
      "adaptiveIcon": {
        "foregroundImage": "./assets/brand/pet-ecosystem-adaptive-foreground.png",
        "backgroundColor": "#f8f4ec"
      }
    },
    "plugins": [
      [
        "@maplibre/maplibre-react-native",
        {
          "android": {
            "locationEngine": "default"
          }
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "e5396697-a4cc-4fd4-b827-4329585b8166"
      }
    }
  }
}
