{
  "name": "@pet/api-client",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "dependencies": {
    "@pet/config": "workspace:*",
    "@pet/types": "workspace:*",
    "@supabase/supabase-js": "^2.57.2"
  },
  "scripts": {
    "build": "tsc --noEmit",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "node -e \"console.log('No tests configured for @pet/api-client yet.')\"",
    "smoke:mvp": "node --import ./scripts/smoke/register-ts-loader.mjs ./scripts/smoke/run-mvp.ts full",
    "smoke:mvp:critical": "node --import ./scripts/smoke/register-ts-loader.mjs ./scripts/smoke/run-mvp.ts critical",
    "smoke:mvp:admin": "node --import ./scripts/smoke/register-ts-loader.mjs ./scripts/smoke/run-mvp.ts admin",
    "smoke:mvp:providers": "node --import ./scripts/smoke/register-ts-loader.mjs ./scripts/smoke/run-mvp.ts providers",
    "smoke:mvp:health": "node --import ./scripts/smoke/register-ts-loader.mjs ./scripts/smoke/run-mvp.ts health",
    "smoke:mvp:reminders": "node --import ./scripts/smoke/register-ts-loader.mjs ./scripts/smoke/run-mvp.ts reminders"
  }
}
